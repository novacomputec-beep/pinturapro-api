# =============================================
#  PINTURAPRO API — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha
# =============================================

# Servidor
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui
SUPABASE_ANON_KEY=sua_anon_key_aqui

# JWT
JWT_SECRET=uma_string_longa_e_secreta_aqui
JWT_EXPIRES_IN=7d

# Mercado Pago
MP_ACCESS_TOKEN=seu_access_token_mercadopago
MP_WEBHOOK_SECRET=seu_webhook_secret

# E-mail (Nodemailer — pode usar Gmail ou SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app
EMAIL_FROM=PinturaPro <noreply@pinturapro.com.br>

# App
FRONTEND_URL=http://localhost:8081
ADMIN_URL=http://localhost:3001
